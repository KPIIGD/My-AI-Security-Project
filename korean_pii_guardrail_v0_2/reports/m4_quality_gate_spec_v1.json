      "pass_criteria": {
        "sweep_locks_recorded_before_run": true,
        "current_delta_auto_selection_allowed": false,
        "high_risk_recall_regression_allowed": false,
        "actionable_high_risk_recall_regression_allowed": false,
        "hard_negative_actionable_fp_increase_allowed": false,
