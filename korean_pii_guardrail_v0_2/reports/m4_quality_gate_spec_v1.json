{
  "version": "v0.2-single-turn",
  "stage": "0.3 gate spec lock",
  "report_type": "M4QualityGateSpec",
  "runtime_scoring_behavior_changed": false,
  "score_delta_changed": false,
  "context_rule_changed": false,
  "gates": [
    {
      "gate_id": "data_quality",
      "name": "Data Quality Gate",
      "required_before_score_or_rule_proposal": true,
      "evidence_artifacts": [
        "context_anchor_windows_manifest_v1.yaml"
      ],
      "measurements": [
        "raw_pii_leak_count",
        "invalid_offset_count",
        "domain_count_by_entity",
        "max_single_domain_ratio_by_entity",
        "realistic_input_like_ratio",
        "general_web_or_explanatory_ratio",
        "example_or_sample_document_ratio",
        "duplicate_anchor_window_ratio",
        "unknown_label_ratio"
      ],
      "pass_criteria": {
        "raw_pii_leak_count": 0,
        "invalid_offset_count": 0,
        "min_domain_count_by_core_entity": 5,
        "max_single_domain_ratio": 0.35,
        "min_realistic_input_like_ratio": 0.7,
        "max_general_web_or_explanatory_ratio": 0.3,
        "max_example_or_sample_document_ratio": 0.15,
        "max_duplicate_anchor_window_ratio": 0.05,
        "max_unknown_label_ratio_when_labels_present": 0.15
      },
      "failure_verdicts": [
        "rejected_data_quality_gate",
        "evidence_backlog",
        "needs_more_data",
        "needs_domain_split"
      ]
    },
    {
      "gate_id": "label_quality",
      "name": "Label Quality Gate",
      "required_before_score_or_rule_proposal": true,
      "evidence_artifacts": [
        "context_label_quality_v1.json",
        "context_anchor_label_audit_v1.jsonl"
      ],
      "measurements": [
        "label_source_counts",
        "final_probability_label_source",
        "stratified_reviewer_sample_count",
        "agreement_score",
        "disagreement_ratio",
        "unknown_label_ratio"
      ],
      "pass_criteria": {
        "final_probability_label_source": "reviewer_approved",
        "sample_stratified_by": [
          "entity",
          "domain",
          "label"
        ],
        "minimum_sample_rule": "max(5_percent, 1000_rows_when_available)",
        "min_agreement": 0.85,
        "max_disagreement_ratio": 0.1,
        "unknown_excluded_from_final_tuning": true
      },
      "failure_verdicts": [
        "rejected_label_quality_gate",
        "needs_more_labels",
        "needs_adjudication"
      ]
    },
    {
      "gate_id": "hard_negative",
